# Start with PayPal Sandbox
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET

# Stripe API Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/jmunz_store?retryWrites=true&w=majority

# Admin Dashboard
ADMIN_PASSWORD=1234
JWT_SECRET=YOUR_RANDOM_SECRET_KEY

# Public HTTPS URL used by PayPal to send payment notifications.
# Localhost cannot receive PayPal notify callbacks.
BASE_URL=http://localhost:3000
PORT=3000
